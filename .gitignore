Pipfile.lock
poetry.lock

# === Archivos de datos sensibles ===
# Excluye cualquier archivo con credenciales o datos privados
*.json
*.yml
*.yaml
!requirements.yml  # Excepción: si tienes un archivo de dependencias
!config/*.yml      # Excepción: si tienes configuraciones no sensibles
token.txt
